{
  "name": "securelens",
  "displayName": "SecureLens",
  "description": "Local-first VS Code security assistant combining Semgrep, custom regex rules, and actionable fixes.",
  "version": "0.0.6",
  "publisher": "Danton-Soares",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "icon": "resources/securelens.png",
  "repository": "https://github.com/Danton1/HackTheBreak2026",
  "categories": [
    "Other",
    "Linters"
  ],
  "activationEvents": [
    "onCommand:securelens.scanCurrentFile",
    "onCommand:securelens.scanWorkspace",
    "onCommand:securelens.openFinding",
    "onCommand:securelens.dismissFinding",
    "onCommand:securelens.dismissAllFindings",
    "onCommand:securelens.quickfix.showEvalGuidance",
    "onView:securelens.actionsView",
    "onView:securelens.findingsView",
    "onView:securelens.suggestionsView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "securelens.scanCurrentFile",
        "title": "SecureLens: Scan Current File",
        "category": "SecureLens",
        "icon": "$(file-code)"
      },
      {
        "command": "securelens.scanWorkspace",
        "title": "SecureLens: Scan Workspace",
        "category": "SecureLens",
        "icon": "$(folder-opened)"
      },
      {
        "command": "securelens.openFinding",
        "title": "SecureLens: Open Finding",
        "category": "SecureLens"
      },
      {
        "command": "securelens.dismissFinding",
        "title": "SecureLens: Dismiss Finding",
        "category": "SecureLens",
        "icon": "$(close)"
      },
      {
        "command": "securelens.dismissAllFindings",
        "title": "SecureLens: Dismiss All Findings",
        "category": "SecureLens",
        "icon": "$(clear-all)"
      },
      {
        "command": "securelens.quickfix.showEvalGuidance",
        "title": "SecureLens: Show Safer Eval Guidance",
        "category": "SecureLens"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "securelens",
          "title": "SecureLens",
          "icon": "resources/securelens.svg"
        }
      ]
    },
    "views": {
      "securelens": [
        {
          "id": "securelens.actionsView",
          "name": "Actions"
        },
        {
          "id": "securelens.findingsView",
          "name": "Findings"
        },
        {
          "id": "securelens.suggestionsView",
          "name": "Suggestions"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "securelens.scanCurrentFile",
          "when": "view == securelens.actionsView",
          "group": "navigation"
        },
        {
          "command": "securelens.scanWorkspace",
          "when": "view == securelens.actionsView",
          "group": "navigation"
        },
        {
          "command": "securelens.scanCurrentFile",
          "when": "view == securelens.findingsView",
          "group": "navigation"
        },
        {
          "command": "securelens.scanWorkspace",
          "when": "view == securelens.findingsView",
          "group": "navigation"
        },
        {
          "command": "securelens.dismissAllFindings",
          "when": "view == securelens.findingsView",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "securelens.dismissFinding",
          "when": "view == securelens.findingsView && viewItem == securelensFinding",
          "group": "inline"
        },
        {
          "command": "securelens.dismissFinding",
          "when": "view == securelens.findingsView && viewItem == securelensFinding",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "SecureLens",
      "properties": {
        "securelens.rerunScanOnQuickFix": {
          "type": "boolean",
          "default": true,
          "description": "Rerun SecureLens scan automatically after applying a SecureLens quick fix."
        },
        "securelens.customRegexRules": {
          "type": "array",
          "default": [],
          "markdownDescription": "Custom regex security rules to run alongside built-in SecureLens regex checks. Invalid rules are skipped safely.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "pattern",
              "message"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Stable unique id for this custom rule."
              },
              "name": {
                "type": "string",
                "description": "Human-friendly rule name shown in finding details."
              },
              "pattern": {
                "type": "string",
                "description": "JavaScript regex pattern string (without leading/trailing slashes)."
              },
              "flags": {
                "type": "string",
                "default": "i",
                "description": "Regex flags, for example \"i\" or \"im\". Global matching is added automatically."
              },
              "severity": {
                "type": "string",
                "enum": [
                  "ERROR",
                  "WARNING",
                  "INFO"
                ],
                "default": "WARNING"
              },
              "category": {
                "type": "string",
                "default": "generic-security-warning"
              },
              "message": {
                "type": "string",
                "description": "Finding message shown in the tree and diagnostics."
              },
              "explanation": {
                "type": "string",
                "description": "Optional human-friendly explanation shown in finding details."
              },
              "detailedSolution": {
                "type": "string",
                "description": "Optional remediation guidance shown in finding details."
              },
              "fileExtensions": {
                "type": "array",
                "description": "Optional extension filter, for example [\".js\", \".ts\"].",
                "items": {
                  "type": "string"
                }
              },
              "source": {
                "type": "string",
                "default": "custom-regex",
                "description": "Optional source label. Use \"custom-regex\" (default) or \"regex\"."
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.2"
  }
}
