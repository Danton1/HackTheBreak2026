{
  "name": "securelens",
  "displayName": "SecureLens",
  "description": "Scan the current file or workspace with Semgrep and surface findings inside VS Code.",
  "version": "0.0.1",
  "publisher": "hackthebreak2026",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "activationEvents": [
    "onCommand:securelens.scanCurrentFile",
    "onCommand:securelens.scanWorkspace",
    "onCommand:securelens.openFinding",
    "onView:securelens.findings"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "securelens.scanCurrentFile",
        "title": "SecureLens: Scan Current File",
        "category": "SecureLens"
      },
      {
        "command": "securelens.scanWorkspace",
        "title": "SecureLens: Scan Workspace",
        "category": "SecureLens"
      },
      {
        "command": "securelens.openFinding",
        "title": "SecureLens: Open Finding",
        "category": "SecureLens"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "securelens",
          "title": "SecureLens",
          "icon": "resources/securelens.svg"
        }
      ]
    },
    "views": {
      "securelens": [
        {
          "id": "securelens.findings",
          "name": "SecureLens Findings"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.2"
  }
}
