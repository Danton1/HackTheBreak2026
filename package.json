{
  "name": "securelens",
  "displayName": "SecureLens",
  "description": "Scan the current file or workspace with Semgrep and surface findings inside VS Code.",
  "version": "0.0.1",
  "publisher": "hackthebreak2026",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "activationEvents": [
    "onCommand:securelens.scanCurrentFile",
    "onCommand:securelens.scanWorkspace",
    "onCommand:securelens.openFinding",
    "onCommand:securelens.dismissFinding",
    "onView:securelens.actionsView",
    "onView:securelens.findingsView",
    "onView:securelens.suggestionsView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "securelens.scanCurrentFile",
        "title": "SecureLens: Scan Current File",
        "category": "SecureLens",
        "icon": "$(file-code)"
      },
      {
        "command": "securelens.scanWorkspace",
        "title": "SecureLens: Scan Workspace",
        "category": "SecureLens",
        "icon": "$(folder-opened)"
      },
      {
        "command": "securelens.openFinding",
        "title": "SecureLens: Open Finding",
        "category": "SecureLens"
      },
      {
        "command": "securelens.dismissFinding",
        "title": "SecureLens: Dismiss Finding",
        "category": "SecureLens",
        "icon": "$(close)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "securelens",
          "title": "SecureLens",
          "icon": "resources/securelens.svg"
        }
      ]
    },
    "views": {
      "securelens": [
        {
          "id": "securelens.actionsView",
          "name": "Actions"
        },
        {
          "id": "securelens.findingsView",
          "name": "Findings"
        },
        {
          "id": "securelens.suggestionsView",
          "name": "Suggestions"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "securelens.scanCurrentFile",
          "when": "view == securelens.actionsView",
          "group": "navigation"
        },
        {
          "command": "securelens.scanWorkspace",
          "when": "view == securelens.actionsView",
          "group": "navigation"
        },
        {
          "command": "securelens.scanCurrentFile",
          "when": "view == securelens.findingsView",
          "group": "navigation"
        },
        {
          "command": "securelens.scanWorkspace",
          "when": "view == securelens.findingsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "securelens.dismissFinding",
          "when": "view == securelens.findingsView && viewItem == securelensFinding",
          "group": "inline"
        },
        {
          "command": "securelens.dismissFinding",
          "when": "view == securelens.findingsView && viewItem == securelensFinding",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.2"
  }
}
